generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SustainabilityRisk {
  LOW
  MEDIUM
  HIGH
}

enum MoveStatus {
  READY
  DONE
  WAITING
}

model Product {
  id                Int                @id @default(autoincrement())
  name              String
  sku               String             @unique
  qtyAvailable      Float              @default(0)
  reorderingMaxQty  Float              @default(0)
  sustainabilityRisk SustainabilityRisk @default(LOW)
  lastMoveAt        DateTime?
  quants            StockQuant[]
  moves             StockMove[]
  ghostRecoveries   GhostRecovery[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Warehouse {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  code      String      @unique
  quants    StockQuant[]
  locations Location[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Location {
  id            Int             @id @default(autoincrement())
  name          String
  code          String          @unique
  activityIndex Int             @default(0)
  removalOrder  Int             @default(0)
  warehouseId   Int
  warehouse     Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quants        StockQuant[]
  sourceMoves   StockMove[]     @relation("SourceLocation")
  destMoves     StockMove[]     @relation("DestLocation")
  ghostRecoveries GhostRecovery[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([activityIndex])
  @@index([warehouseId])
}

model StockQuant {
  id          Int       @id @default(autoincrement())
  productId   Int
  warehouseId Int
  locationId  Int
  quantity    Float     @default(0)
  reserved    Float     @default(0)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  location    Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId, locationId])
  @@index([productId])
  @@index([locationId])
}

model StockMove {
  id               Int        @id @default(autoincrement())
  productId        Int
  quantity         Float
  status           MoveStatus @default(READY)
  sourceLocationId Int
  destLocationId   Int
  validatedBy      String?
  validatedAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  product          Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceLocation   Location   @relation("SourceLocation", fields: [sourceLocationId], references: [id], onDelete: Restrict)
  destLocation     Location   @relation("DestLocation", fields: [destLocationId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([validatedBy, validatedAt])
}

model UserScore {
  id        Int      @id @default(autoincrement())
  name      String
  avatarUrl String
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliveryProgress {
  id             Int      @id @default(autoincrement())
  readyCount     Int      @default(0)
  doneTodayCount Int      @default(0)
  capturedAt     DateTime @default(now())
}

model GhostRecovery {
  id          Int      @id @default(autoincrement())
  productId   Int
  locationId  Int
  quantity    Float
  scannedImage String?
  note        String
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}
