generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums

enum UserRole {
  Manager
  Staff
}

enum OperationType {
  Receipt
  Delivery
  Internal
  Adjustment
}

enum OperationStatus {
  Draft
  Waiting
  Ready
  Done
  Cancelled
}

// Users

model User {
  id             String      @id @default(uuid())
  name           String
  email          String      @unique
  passwordHash   String      @map("password_hash")
  role           UserRole    @default(Staff)
  resetOtp       String?     @map("reset_otp")
  resetOtpExpiry DateTime?   @map("reset_otp_expiry")
  createdAt      DateTime    @default(now()) @map("created_at")
  operations     Operation[]

  @@map("users")
}

// Warehouses

model Warehouse {
  id        String     @id @default(uuid())
  name      String
  shortCode String     @unique @map("short_code")
  address   String?
  createdAt DateTime   @default(now()) @map("created_at")
  locations Location[]

  @@map("warehouses")
}

// Locations

model Location {
  id              String             @id @default(uuid())
  warehouse       Warehouse?         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  warehouseId     String?            @map("warehouse_id")
  name            String
  shortCode       String             @map("short_code")
  isScrap         Boolean            @default(false) @map("is_scrap")
  stockLevels     StockLevel[]
  srcOperations   Operation[]        @relation("SrcLocation")
  destOperations  Operation[]        @relation("DestLocation")
  fromMoveHistory StockMoveHistory[] @relation("FromLocation")
  toMoveHistory   StockMoveHistory[] @relation("ToLocation")

  @@map("locations")
}

// Categories

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  products    Product[]

  @@map("categories")
}

// Products

model Product {
  id                String             @id @default(uuid())
  name              String
  skuCode           String             @unique @map("sku_code")
  category          Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId        String?            @map("category_id")
  uom               String             @default("Units")
  description       String?
  lowStockThreshold Int                @default(10) @map("low_stock_threshold")
  stockLevels       StockLevel[]
  operationItems    OperationItem[]
  moveHistory       StockMoveHistory[]

  @@map("products")
}

// Stock Levels

model StockLevel {
  id           String   @id @default(uuid())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String   @map("product_id")
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId   String   @map("location_id")
  qtyOnHand    Decimal  @default(0) @map("qty_on_hand")
  qtyAvailable Decimal  @default(0) @map("qty_available")

  @@map("stock_levels")
}

// Operations

model Operation {
  id                String          @id @default(uuid())
  refNo             String          @unique @map("ref_no")
  type              OperationType
  srcLocation       Location?       @relation("SrcLocation", fields: [srcLocationId], references: [id])
  srcLocationId     String?         @map("src_location_id")
  destLocation      Location?       @relation("DestLocation", fields: [destLocationId], references: [id])
  destLocationId    String?         @map("dest_location_id")
  contact           String?
  scheduledDate     DateTime?       @map("scheduled_date")
  status            OperationStatus @default(Draft)
  responsibleUser   User?           @relation(fields: [responsibleUserId], references: [id])
  responsibleUserId String?         @map("responsible_user_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  items             OperationItem[]
  moveHistory       StockMoveHistory[]

  @@map("operations")
}

// Operation Items

model OperationItem {
  id          String    @id @default(uuid())
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  operationId String    @map("operation_id")
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String    @map("product_id")
  demandQty   Decimal   @map("demand_qty")
  doneQty     Decimal   @default(0) @map("done_qty")

  @@map("operation_items")
}

// Stock Move History (immutable ledger)

model StockMoveHistory {
  id             String     @id @default(uuid())
  product        Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId      String     @map("product_id")
  fromLocation   Location?  @relation("FromLocation", fields: [fromLocationId], references: [id])
  fromLocationId String?    @map("from_location_id")
  toLocation     Location?  @relation("ToLocation", fields: [toLocationId], references: [id])
  toLocationId   String?    @map("to_location_id")
  quantity       Decimal
  operation      Operation? @relation(fields: [operationId], references: [id])
  operationId    String?    @map("operation_id")
  timestamp      DateTime   @default(now())

  @@map("stock_move_history")
}
